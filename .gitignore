# ──────────────────────────────────────────────
# EcoSphere — .gitignore
# ──────────────────────────────────────────────

# IDE / editors
.idea/
.vscode/

# Node.js
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.eslintcache
.yarn-integrity

# React / CRA
/coverage
/build

# Next.js (if ever used)
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# Production builds
dist/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
venv/
.venv/
*.egg-info/
.eggs/
.pytest_cache/

# Environment files — NEVER commit these
.env
.env.*
*.env
backend/.env
frontend/.env

# Secret / credential files
*token.json*
*credentials.json*
credentials.json
*.pem
*.key
*.keystore
.credentials

# Logs
*.log
dump.rdb

# System files
.DS_Store
Thumbs.db

# Archive / binary assets
**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack
*.deb
*.dylib

# Build caches
.cache/

# Agent / platform-specific (not part of the project)
.emergent/
memory/test_credentials.md
test_reports/
design_guidelines.json
mongo_dump/

# Deployment tools
.vercel
